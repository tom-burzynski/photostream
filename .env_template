# Docker environment variables template for photostream
# Copy this file to .env and fill in your values

# Site configuration
TITLE=
DESCRIPTION=
FOOTER=

# Footer links
LINK1_TITLE=
LINK1_URL=
LINK2_TITLE=
LINK2_URL=
LINK3_TITLE=
LINK3_URL=

# Image processing settings
PREVIEW_HEIGHT=400
PRELOAD_COUNT=20
PAGE_SIZE=30
WORKERS=4

# Feature flags
RENAME=false
GEOCODE=false
REGEOCODE=false

# Deployment settings
DEPLOY=false
DEPLOY_METHOD=

# Docker watcher settings
WATCH_DELAY=5
RUN_ON_STARTUP=true
LOG_LEVEL=INFO
WEB_SERVER_PORT=8080