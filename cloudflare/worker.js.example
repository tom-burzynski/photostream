// Cloudflare Worker for Backblaze B2 Photo Gallery
// Proxies requests to B2 bucket with intelligent caching

addEventListener('fetch', event => {
  event.respondWith(handleRequest(event.request))
})

async function handleRequest(request) {
  const url = new URL(request.url)

  // Your B2 bucket configuration
  const B2_BUCKET_ENDPOINT = 'YOUR_BUCKET.s3.us-west-004.backblazeb2.com'
  const B2_BUCKET_URL = `https://${B2_BUCKET_ENDPOINT}`

  // Handle root path - serve index.html
  let path = url.pathname
  if (path === '/' || path === '') {
    path = '/index.html'
  }

  // Build the B2 URL
  const b2Url = `${B2_BUCKET_URL}${path}`

  // Check cache first
  const cache = caches.default
  let response = await cache.match(request)

  if (response) {
    // Cache hit - return cached response with header indicating cache status
    response = new Response(response.body, response)
    response.headers.set('X-Cache-Status', 'HIT')
    return response
  }

  // Cache miss - fetch from B2
  try {
    response = await fetch(b2Url, {
      cf: {
        // Cloudflare-specific caching options
        cacheTtl: 86400, // Cache for 24 hours
        cacheEverything: true,
      }
    })

    // If file not found and path doesn't have extension, try adding .html
    if (response.status === 404 && !path.includes('.')) {
      const htmlPath = path.endsWith('/') ? `${path}index.html` : `${path}.html`
      const htmlUrl = `${B2_BUCKET_URL}${htmlPath}`
      response = await fetch(htmlUrl, {
        cf: {
          cacheTtl: 86400,
          cacheEverything: true,
        }
      })
    }

    // Clone response so we can modify headers
    response = new Response(response.body, response)

    // Add cache control headers
    if (response.ok) {
      // Set appropriate cache headers based on content type
      const contentType = response.headers.get('content-type') || ''

      if (contentType.includes('text/html')) {
        // HTML files - shorter cache, allow revalidation
        response.headers.set('Cache-Control', 'public, max-age=3600, must-revalidate')
      } else if (contentType.includes('image/')) {
        // Images - long cache since they're immutable
        response.headers.set('Cache-Control', 'public, max-age=31536000, immutable')
      } else {
        // Other files - moderate cache
        response.headers.set('Cache-Control', 'public, max-age=86400')
      }

      // Add cache status header
      response.headers.set('X-Cache-Status', 'MISS')

      // Store in cache for next time
      event.waitUntil(cache.put(request, response.clone()))
    }

    return response

  } catch (error) {
    return new Response('Error fetching from B2: ' + error.message, {
      status: 502,
      headers: { 'Content-Type': 'text/plain' }
    })
  }
}
